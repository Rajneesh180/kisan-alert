# Gemini API key from https://aistudio.google.com (free tier, no card).
# Powers the advisory, photo diagnosis, native text-to-speech, and RAG
# embeddings — all on the one free key, no billing or extra APIs to enable.
GEMINI_API_KEY=
# Confirm current stable Flash id in AI Studio when creating the key
GEMINI_MODEL=gemini-3.5-flash
# Google Cloud project registered for Earth Engine (pipeline only, not needed by the app)
GEE_PROJECT=

# Optional: Twilio WhatsApp/SMS sandbox so the SMS demo works on a real phone.
# From the Twilio Console (free trial). Point the sandbox's "when a message
# comes in" webhook at https://<your-deploy>/api/twilio/inbound
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886

